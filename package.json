{
  "name": "super-terminal",
  "version": "1.0.0",
  "description": "Super Terminal — Desktop control center for AI coding agents",
  "author": {
    "name": "KhangNT",
    "email": "khangnt@super-terminal.app"
  },
  "main": "./out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "make-icon": "node scripts/make-icon.mjs",
    "package": "electron-vite build && electron-builder --win",
    "package:dir": "electron-vite build && electron-builder --dir",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint . --ext .ts,.tsx",
    "rebuild": "electron-rebuild -f -w node-pty"
  },
  "dependencies": {
    "node-pty": "^1.0.0",
    "@xterm/xterm": "^5.5.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",
    "zustand": "^4.5.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-resizable-panels": "^2.0.0",
    "chokidar": "^3.6.0",
    "simple-git": "^3.25.0"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-vite": "^2.3.0",
    "electron-builder": "^24.13.3",
    "@electron/rebuild": "^3.6.0",
    "vite": "^5.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "typescript": "^5.5.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/node": "^20.14.0",
    "tailwindcss": "^3.4.0",
    "postcss": "^8.4.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^8.57.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "vitest": "^2.0.0",
    "@playwright/test": "^1.45.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "tailwind-merge": "^2.4.0",
    "lucide-react": "^0.400.0",
    "jimp": "^1.6.1",
    "png-to-ico": "^3.0.2"
  },
  "build": {
    "appId": "app.super-terminal.desktop",
    "productName": "Super Terminal",
    "copyright": "Copyright © 2025 KhangNT",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "out/**/*",
      "!out/**/*.map"
    ],
    "icon": "build/icons/icon.ico",
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "build/icons/icon.ico",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "installerIcon": "build/icons/icon.ico",
      "uninstallerIcon": "build/icons/icon.ico",
      "installerHeaderIcon": "build/icons/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Super Terminal",
      "runAfterFinish": true
    },
    "portable": {
      "artifactName": "SuperTerminal-${version}-portable.exe"
    },
    "asar": true,
    "asarUnpack": [
      "**/node_modules/node-pty/**"
    ]
  }
}
